		{
			"name": "📅 Calendar Queries",
			"item": [
				{
					"name": "Lịch cá nhân (tháng này)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const now = new Date();",
									"const year = now.getFullYear();",
									"const month = String(now.getMonth() + 1).padStart(2, '0');",
									"const lastDay = new Date(year, now.getMonth() + 1, 0).getDate();",
									"",
									"pm.collectionVariables.set('calStart', `${year}-${month}-01`);",
									"pm.collectionVariables.set('calEnd', `${year}-${month}-${lastDay}`);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Response là array', () => {",
									"    const res = pm.response.json();",
									"    pm.expect(res).to.be.an('array');",
									"    console.log('📅 Tasks in calendar:', res.length);",
									"});",
									"pm.test('Tasks có đủ fields cho Calendar render', () => {",
									"    const res = pm.response.json();",
									"    if (res.length > 0) {",
									"        const t = res[0];",
									"        pm.expect(t).to.have.property('id');",
									"        pm.expect(t).to.have.property('title');",
									"        pm.expect(t).to.have.property('priority');",
									"        pm.expect(t).to.have.property('category');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{taskServiceUrl}}/tasks/calendar?start={{calStart}}&end={{calEnd}}",
							"host": ["{{taskServiceUrl}}"],
							"path": ["tasks", "calendar"],
							"query": [
								{ "key": "start", "value": "{{calStart}}" },
								{ "key": "end", "value": "{{calEnd}}" }
							]
						}
					}
				},
				{
					"name": "Lịch cá nhân (tuần này)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const now = new Date();",
									"const day = now.getDay();",
									"const monday = new Date(now);",
									"monday.setDate(now.getDate() - day + (day === 0 ? -6 : 1));",
									"const sunday = new Date(monday);",
									"sunday.setDate(monday.getDate() + 6);",
									"",
									"const fmt = d => d.toISOString().split('T')[0];",
									"pm.collectionVariables.set('weekStart', fmt(monday));",
									"pm.collectionVariables.set('weekEnd', fmt(sunday));"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Response là array', () => pm.expect(pm.response.json()).to.be.an('array'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{taskServiceUrl}}/tasks/calendar?start={{weekStart}}&end={{weekEnd}}",
							"host": ["{{taskServiceUrl}}"],
							"path": ["tasks", "calendar"],
							"query": [
