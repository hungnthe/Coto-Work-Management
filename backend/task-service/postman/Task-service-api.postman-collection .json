					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Ngày đã đổi', () => {",
									"    const res = pm.response.json();",
									"    pm.expect(res.startDate).to.eql('2025-04-20');",
