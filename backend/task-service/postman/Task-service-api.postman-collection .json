{
	"info": {
		"_postman_id": "task-service-collection-2025",
		"name": "🗓️ Task Service API - Cô Tô",
		"description": "Postman Collection cho Task Service (port 8084)\n\n## Cách dùng:\n1. Import collection này vào Postman\n2. Import Environment file kèm theo\n3. Chạy request \"Login\" trong folder Auth trước để lấy token\n4. Token tự động set vào biến {{accessToken}}, các request sau tự dùng\n\n## Thứ tự test:\n1. Health Check\n2. Login (lấy token)\n3. Create Task\n4. Get Tasks (list)\n5. Get Task by ID\n6. Update Task\n7. Move Task (Calendar drag-drop)\n8. Toggle Complete\n9. Calendar queries\n10. Delete Task",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "taskServiceUrl",
			"value": "http://localhost:8084/api"
		},
		{
			"key": "userServiceUrl",
			"value": "http://localhost:8083/api"
		},
		{
			"key": "accessToken",
			"value": ""
		},
		{
			"key": "taskId",
			"value": ""
		},
		{
			"key": "taskId2",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "🔑 Auth (User Service)",
			"description": "Đăng nhập qua user-service để lấy JWT token",
			"item": [
				{
					"name": "Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const res = pm.response.json();",
									"    ",
									"    // Lưu token",
									"    pm.collectionVariables.set('accessToken', res.accessToken);",
									"    ",
									"    // Lưu user info",
									"    pm.collectionVariables.set('userId', res.userId);",
									"    pm.collectionVariables.set('username', res.username);",
									"    pm.collectionVariables.set('fullName', res.fullName);",
									"    pm.collectionVariables.set('unitId', res.unitId);",
									"    pm.collectionVariables.set('unitName', res.unitName);",
									"    ",
									"    pm.test('Login thành công', () => {",
									"        pm.expect(res.accessToken).to.be.a('string');",
									"        pm.expect(res.role).to.be.oneOf(['ADMIN', 'MANAGER']);",
									"    });",
									"    ",
									"    pm.test('Có permissions', () => {",
									"        pm.expect(res.permissions).to.be.an('array');",
									"        pm.expect(res.permissions.length).to.be.greaterThan(0);",
									"    });",
									"    ",
									"    console.log('✅ Token saved. User:', res.username, 'Role:', res.role);",
									"} else {",
									"    pm.test('Login failed: ' + pm.response.code, () => pm.expect.fail());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{userServiceUrl}}/auth/login",
							"host": ["{{userServiceUrl}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "❤️ Health Check",
			"item": [
				{
					"name": "Task Service Health",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Service is healthy', () => {",
									"    pm.response.to.have.status(200);",
									"    pm.expect(pm.response.text()).to.include('healthy');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"url": {
							"raw": "{{taskServiceUrl}}/tasks/health",
							"host": ["{{taskServiceUrl}}"],
							"path": ["tasks", "health"]
						}
					}
				}
			]
		},
		{
			"name": "📝 CRUD - Tạo Task",
			"item": [
				{
					"name": "Tạo task đầy đủ",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    pm.collectionVariables.set('taskId', res.id);",
									"    ",
									"    pm.test('Task created - 201', () => {",
									"        pm.response.to.have.status(201);",
									"    });",
									"    pm.test('Có ID', () => pm.expect(res.id).to.be.a('number'));",
									"    pm.test('Title đúng', () => pm.expect(res.title).to.eql('Họp giao ban tuần'));",
									"    pm.test('Priority đúng', () => pm.expect(res.priority).to.eql('HIGH'));",
									"    pm.test('Category đúng', () => pm.expect(res.category).to.eql('meeting'));",
									"    pm.test('Có creatorId', () => pm.expect(res.creatorId).to.be.a('number'));",
									"    ",
									"    console.log('✅ Task created ID:', res.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Họp giao ban tuần\",\n    \"description\": \"Tổng kết công việc tuần trước, phân công tuần mới\",\n    \"startDate\": \"{{$isoTimestamp}}\",\n    \"dueDate\": \"{{$isoTimestamp}}\",\n    \"startTime\": \"08:00:00\",\n    \"endTime\": \"09:30:00\",\n    \"status\": \"TODO\",\n    \"priority\": \"HIGH\",\n    \"category\": \"meeting\",\n    \"isAllDay\": false,\n    \"location\": \"Phòng họp A1\",\n    \"assigneeName\": \"Admin\",\n    \"unitName\": \"Phòng Hành chính\"\n}"
						},
						"url": {
							"raw": "{{taskServiceUrl}}/tasks",
							"host": ["{{taskServiceUrl}}"],
							"path": ["tasks"]
						}
					}
				},
				{
					"name": "Tạo task tối giản",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    pm.collectionVariables.set('taskId2', res.id);",
									"    ",
									"    pm.test('Task created - 201', () => pm.response.to.have.status(201));",
									"    pm.test('Default status = TODO', () => pm.expect(res.status).to.eql('TODO'));",
									"    pm.test('Default priority = MEDIUM', () => pm.expect(res.priority).to.eql('MEDIUM'));",
									"    pm.test('Default category = work', () => pm.expect(res.category).to.eql('work'));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Viết báo cáo tháng\",\n    \"dueDate\": \"2025-04-15\"\n}"
