									"});",
									"pm.test('Có validation errors', () => {",
									"    const res = pm.response.json();",
									"    pm.expect(res.details.validationErrors).to.be.an('array');",
									"    pm.expect(res.details.validationErrors.length).to.be.greaterThan(0);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"description\": \"Task không có title\"\n}"
						},
						"url": {
							"raw": "{{taskServiceUrl}}/tasks",
							"host": ["{{taskServiceUrl}}"],
							"path": ["tasks"]
						}
					}
				}
			]
		},
		{
